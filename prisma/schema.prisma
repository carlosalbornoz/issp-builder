generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// ENUMS
// ============================================================

enum AgencyType {
  NGA
  GOCC
  LGU
  OTHER
}

enum UserRole {
  ADMIN
  CIO
  FOCAL
  CONTRIBUTOR
}

enum DocStatus {
  DRAFT
  REVIEW
  SUBMITTED
  APPROVED
}

enum IsspScope {
  DEPARTMENT_WIDE
  DEPARTMENT_CENTRAL_ONLY
  CENTRAL_ONLY
  WITH_REGIONAL
  WITH_BUREAUS
  AGENCY_WIDE
  AGENCY_CENTRAL_ONLY
  AGENCY_WITH_REGIONAL
  OTHER_GOVERNMENT_ENTITY
  LGU_SCOPE
}

// ============================================================
// CORE MODELS
// ============================================================

model Agency {
  id        String   @id @default(cuid())
  name      String
  acronym   String   @unique
  type      AgencyType
  logoPath  String?
  websiteUrl String?
  users     User[]
  isspDocs  IsspDocument[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  isspDocs  IsspDocument[]
  createdAt DateTime @default(now())

  @@index([agencyId])
}

model IsspDocument {
  id              String    @id @default(cuid())
  title           String
  startYear       Int
  endYear         Int
  status          DocStatus @default(DRAFT)
  amendmentNumber Int       @default(0)
  scope           IsspScope
  agencyId        String
  agency          Agency    @relation(fields: [agencyId], references: [id])
  createdBy       String
  creator         User      @relation(fields: [createdBy], references: [id])
  part1           Part1Profile?
  part2           Part2Assessment?
  part3           Part3Strategy?
  part4           Part4Resources?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([agencyId])
  @@index([createdBy])
}

// ============================================================
// PART I — AGENCY PROFILE & STRATEGIC CONTEXT
// ============================================================

model Part1Profile {
  id              String   @id @default(cuid())
  isspDocId       String   @unique
  isspDoc         IsspDocument @relation(fields: [isspDocId], references: [id], onDelete: Cascade)

  // A.1 Mandate
  legalBasis      String   @default("")
  mandateFunction String   @default("")

  // A.2-4 Vision, Mission, Org Outcomes
  visionStatement  String   @default("")
  missionStatement String   @default("")
  orgOutcomes     String   @default("[]")
  // JSON: Array<{ name: string, programs: string[] }>
  // OO for NGAs, SO for GOCCs, MFO for LGUs

  // B.1 CIO
  cioName         String   @default("")
  cioPosition     String   @default("")
  cioUnit         String   @default("")
  cioEmail        String   @default("")
  cioContact      String   @default("")

  // B.1 ISSP Focal
  focalName       String   @default("")
  focalPosition   String   @default("")
  focalUnit       String   @default("")
  focalEmail      String   @default("")
  focalContact    String   @default("")

  // B.2 Human Capital
  humanCapital    String   @default("{}")
  // JSON: { plantilla: { it: { male: n, female: n }, nonIt: { male: n, female: n } }, ... }

  // C. Stakeholders
  stakeholders    String   @default("[]")
  // JSON: Array<{ name: string, transactions: string, complexity: "Simple"|"Complex"|"Highly Technical" }>
}

// ============================================================
// PART II — CURRENT ICT ASSESSMENT
// ============================================================

model Part2Assessment {
  id                String   @id @default(cuid())
  isspDocId         String   @unique
  isspDoc           IsspDocument @relation(fields: [isspDocId], references: [id], onDelete: Cascade)

  // A. Strategic Concerns
  strategicConcerns String   @default("[]")
  // JSON: Array<{ ooSoMfo: string, criticalSystem: string, problem: string, intendedIctUse: string }>

  // B.1 Network Infrastructure
  networkDiagramPath String?          // deprecated — superseded by networkDiagrams
  networkDiagrams    String  @default("[]")
  // JSON: Array<{ id: string, path: string, title: string }>
  networkDescription String  @default("")

  // B.2 Cybersecurity Controls
  cybersecurityControls String @default("{}")
  // JSON: { physicalSecurity: { perimeterProtection: bool, ... }, ... }

  // C. Existing Information Systems
  informationSystems String   @default("[]")
  // JSON: Array<{ id, name, classification, frontline, deploymentType, url, description,
  //              developmentStrategy, developmentPlatform, databaseName, dataStorage,
  //              internalUsers, externalUsers, owner, interoperability: {...}, pia: {...} }>

  // D. E-Government Programs Checklist
  egpChecklist      String   @default("{}")
  // JSON: { elgu: {...}, eGovPay: {...}, pnpki: {...}, hcmis: {...}, ifmis: {...},
  //        onlinePortal: {...}, procurement: {...}, recordsMgmt: {...}, pscp: {...} }
}

// ============================================================
// PART III — PROPOSED ICT STRATEGY
// ============================================================

model Part3Strategy {
  id                      String   @id @default(cuid())
  isspDocId               String   @unique
  isspDoc                 IsspDocument @relation(fields: [isspDocId], references: [id], onDelete: Cascade)

  // A.1 Proposed Network Infrastructure
  proposedNetworkDiagram  String?
  proposedNetworkDesc     String   @default("")

  // A.2 Proposed Cybersecurity Controls
  proposedCybersecControls String @default("{}")

  // B. Enterprise Architecture
  enterpriseArchDiagram   String?

  // C. Proposed ICT Human Capital
  proposedHumanCapital    String   @default("[]")
  // JSON: Array<{ position: string, employmentStatus: string, physicalCount: number }>

  // D. Proposed Information Systems (created FIRST)
  proposedSystems         String   @default("[]")
  // JSON: Array<{ id, name, classification, frontline, deploymentType, status,
  //              enhancementDetails, developmentStrategy, developmentPlatform, databaseName,
  //              dataStorage, internalUsers, externalUsers, owner, interoperability,
  //              pia, linkedProjectId }>

  // E.1 Internal ICT Projects (created SECOND)
  internalProjects        String   @default("[]")
  // JSON: Array<{ id, title, description, objectives, projectType, linkedSystemIds,
  //              strategicAlignment, harmonization, duration, year1-3Deliverables,
  //              implementingUnit, totalProjectCost, fundingSource }>

  // E.2 Cross-Agency ICT Projects
  crossAgencyProjects     String   @default("[]")
  // JSON: same as internalProjects + leadAgency, implementingAgency

  // F. Performance Measurement Framework
  performanceFramework    String   @default("{}")
  // JSON: Record<projectId, { projectTitle, projectType, rows: [...] }>
}

// ============================================================
// PART IV — RESOURCE REQUIREMENTS
// ============================================================

model Part4Resources {
  id                String   @id @default(cuid())
  isspDocId         String   @unique
  isspDoc           IsspDocument @relation(fields: [isspDocId], references: [id], onDelete: Cascade)

  // A.1-3 Yearly breakdowns
  year1             String   @default("{}")
  year2             String   @default("{}")
  year3             String   @default("{}")
  // JSON per year: { officeProductivity: { capitalOutlay: [...], mooe: [...] },
  //   internalProjects: { [projectId]: { projectTitle, capitalOutlay: [...], mooe: [...] } },
  //   crossAgencyProjects: { [projectId]: { ... } },
  //   continuingCosts: { mooe: [...] } }
  //
  // Line item: { uacsCode, item, office, fundSource, unitCost, qty, totalCost }
  // Summary is auto-calculated; stored for caching
  summary           String   @default("{}")

  createdAt         DateTime?
  updatedAt         DateTime?
}
